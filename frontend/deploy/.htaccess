<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir las solicitudes de archivos reales
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirigir todo lo demás a index.html (Angular se encarga del enrutamiento)
  RewriteRule ^ index.html [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Configure el paquete "ea-php81" como el lenguaje de programación predeterminado "PHP".
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
